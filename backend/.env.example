# Copy to backend/.env and fill in.

# --- Database ---
DATABASE_URL=sqlite:///./sheep2026.db
# Optional: override SpatiaLite extension path if auto-detection fails.
# SPATIALITE_PATH=/usr/lib/x86_64-linux-gnu/mod_spatialite.so

# --- Pilot neighborhood (Žnjan, Split) ---
# Used as default bbox for source ingestion + frontend map fit.
PILOT_NAME=znjan
PILOT_BBOX_MINX=16.4750
PILOT_BBOX_MINY=43.5050
PILOT_BBOX_MAXX=16.5050
PILOT_BBOX_MAXY=43.5200

# --- External services (fill in as adapters land) ---
# GEE project added in task #5/#7/#10.
# GEE_PROJECT_ID=
# Cesium Ion token used by index.html for Google Photorealistic 3D Tiles.
# CESIUM_ION_TOKEN=
# Anthropic key for the NL query in task #13.
# ANTHROPIC_API_KEY=
